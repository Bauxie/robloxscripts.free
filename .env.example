# Copy to .env.local for local development
# Add the same keys in Vercel → Project Settings → Environment Variables
# After changing env vars on Vercel, you MUST Redeploy.

# Preferred server-side URL (not inlined at build time)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Required for browser auth (login / Discord)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only — never expose this in client code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Canonical site URL (used for safe auth redirects — do not trust Host headers)
NEXT_PUBLIC_SITE_URL=https://robloxscripts.free

# Bootstrap site owners. Prefer UUIDs in production (usernames can be claimed).
# SITE_OWNER_IDS=00000000-0000-0000-0000-000000000000
SITE_OWNER_USERNAMES=bauix

# Contact email shown on /contact (optional)
# NEXT_PUBLIC_CONTACT_EMAIL=hello@robloxscripts.free

# Google Analytics is installed in app/layout.tsx (G-FPKWBYCHHQ) — one tag site-wide.

# Google AdSense (optional — leave blank until approved)
# Client ID looks like: ca-pub-1234567890123456
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# Optional ad slots (create in AdSense → Ads → By ad unit)
# NEXT_PUBLIC_ADSENSE_SLOT_HOME=
# NEXT_PUBLIC_ADSENSE_SLOT_SCRIPT=

# --- Supabase Auth setup (Dashboard) ---
# 1. Run supabase/schema.sql then supabase/auth.sql in the SQL Editor
# 2. Authentication → URL Configuration:
#      Site URL: https://robloxscripts.free
#      Redirect URLs:
#        http://localhost:3000/auth/callback
#        https://robloxscripts.free/auth/callback
# 3. Authentication → Providers:
#      Enable Email
#      Enable Discord (paste Client ID + Secret from Discord Developer Portal)
# 4. Discord Developer Portal → OAuth2 → Redirects:
#      https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
